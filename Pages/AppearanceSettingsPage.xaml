<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="TubaWinUi3.Pages.AppearanceSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TubaWinUi3.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    NavigationCacheMode="Enabled"
    mc:Ignorable="d">

    <Grid Background="Transparent">
        <ScrollViewer
            HorizontalScrollMode="Disabled"
            VerticalScrollBarVisibility="Auto">
            <RelativePanel HorizontalAlignment="Stretch">
                <StackPanel
                    x:Name="ContentPanel"
                    RelativePanel.AlignHorizontalCenterWithPanel="True"
                    RelativePanel.AlignLeftWithPanel="True"
                    RelativePanel.AlignRightWithPanel="True"
                    MaxWidth="1000"
                    Spacing="2"
                    Padding="40,28,40,48">
                    <StackPanel.Transitions>
                        <TransitionCollection>
                            <RepositionThemeTransition />
                        </TransitionCollection>
                    </StackPanel.Transitions>

                    <Grid ColumnSpacing="12" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button
                            x:Name="BackButton"
                            Width="36"
                            Height="36"
                            Padding="0"
                            VerticalAlignment="Center"
                            Click="BackButton_Click">
                            <FontIcon FontSize="14" Glyph="&#xE72B;" />
                        </Button>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock
                                FontSize="28"
                                FontWeight="SemiBold"
                                Text="外观" />
                            <TextBlock
                                Opacity="0.72"
                                Text="窗口材质、背景图片、水印等个性化设置" />
                        </StackPanel>
                    </Grid>

                    <Border x:Name="SettingsBackdropCard" Style="{StaticResource SettingsCardStyle}">
                        <Grid RowSpacing="14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Style="{StaticResource IconBorderStyle}">
                                    <FontIcon FontSize="18" Glyph="&#xE7F3;" />
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                    <TextBlock FontWeight="SemiBold" Text="窗口材质" />
                                    <TextBlock
                                        Opacity="0.68"
                                        FontSize="13"
                                        TextWrapping="Wrap"
                                        Text="选择窗口背景的视觉材质效果" />
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="1" ColumnSpacing="8" HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border
                                    x:Name="BackdropMicaOption"
                                    Tag="Mica"
                                    CornerRadius="8"
                                    BorderThickness="2"
                                    BorderBrush="{ThemeResource SubtleFillColorSecondaryBrush}"
                                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                    Padding="10,8"
                                    Tapped="BackdropOption_Tapped"
                                    PointerEntered="BackdropOption_PointerEntered"
                                    PointerExited="BackdropOption_PointerExited">
                                    <StackPanel HorizontalAlignment="Center" Spacing="4">
                                        <Border
                                            Width="48"
                                            Height="32"
                                            CornerRadius="4"
                                            Background="#1A000000">
                                            <Border
                                                CornerRadius="3"
                                                Margin="3"
                                                Background="#0CFFFFFF">
                                                <Border
                                                    CornerRadius="2"
                                                    Margin="2"
                                                    Background="#08FFFFFF" />
                                            </Border>
                                        </Border>
                                        <TextBlock
                                            FontSize="11"
                                            HorizontalAlignment="Center"
                                            Text="Mica" />
                                    </StackPanel>
                                </Border>

                                <Border
                                    x:Name="BackdropMicaAltOption"
                                    Grid.Column="1"
                                    Tag="MicaAlt"
                                    CornerRadius="8"
                                    BorderThickness="2"
                                    BorderBrush="{ThemeResource SubtleFillColorSecondaryBrush}"
                                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                    Padding="10,8"
                                    Tapped="BackdropOption_Tapped"
                                    PointerEntered="BackdropOption_PointerEntered"
                                    PointerExited="BackdropOption_PointerExited">
                                    <StackPanel HorizontalAlignment="Center" Spacing="4">
                                        <Border
                                            Width="48"
                                            Height="32"
                                            CornerRadius="4"
                                            Background="#2A000000">
                                            <Border
                                                CornerRadius="3"
                                                Margin="3"
                                                Background="#14FFFFFF">
                                                <Border
                                                    CornerRadius="2"
                                                    Margin="2"
                                                    Background="#0AFFFFFF" />
                                            </Border>
                                        </Border>
                                        <TextBlock
                                            FontSize="11"
                                            HorizontalAlignment="Center"
                                            Text="Mica Alt" />
                                    </StackPanel>
                                </Border>

                                <Border
                                    x:Name="BackdropAcrylicOption"
                                    Grid.Column="2"
                                    Tag="Acrylic"
                                    CornerRadius="8"
                                    BorderThickness="2"
                                    BorderBrush="{ThemeResource SubtleFillColorSecondaryBrush}"
                                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                    Padding="10,8"
                                    Tapped="BackdropOption_Tapped"
                                    PointerEntered="BackdropOption_PointerEntered"
                                    PointerExited="BackdropOption_PointerExited">
                                    <StackPanel HorizontalAlignment="Center" Spacing="4">
                                        <Border
                                            Width="48"
                                            Height="32"
                                            CornerRadius="4">
                                            <Border.Background>
                                                <AcrylicBrush
                                                    TintColor="#FF202020"
                                                    TintOpacity="0.8"
                                                    TintLuminosityOpacity="0.3" />
                                            </Border.Background>
                                            <Border
                                                CornerRadius="3"
                                                Margin="4"
                                                Background="#18FFFFFF" />
                                        </Border>
                                        <TextBlock
                                            FontSize="11"
                                            HorizontalAlignment="Center"
                                            Text="毛玻璃" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border x:Name="SettingsBackgroundCard" Style="{StaticResource SettingsCardStyle}">
                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Style="{StaticResource IconBorderStyle}">
                                    <FontIcon FontSize="18" Glyph="&#xE91B;" />
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                    <TextBlock FontWeight="SemiBold" Text="背景图片" />
                                    <TextBlock
                                        Opacity="0.68"
                                        FontSize="13"
                                        TextWrapping="Wrap"
                                        Text="导入图片作为主页面背景" />
                                </StackPanel>

                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <Button
                                        x:Name="ClearBgButton"
                                        Padding="10,6"
                                        Click="ClearBgButton_Click"
                                        Visibility="Collapsed">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon FontSize="12" Glyph="&#xE711;" />
                                            <TextBlock Text="清除" />
                                        </StackPanel>
                                    </Button>
                                    <Button
                                        x:Name="ImportBgButton"
                                        Padding="10,6"
                                        Click="ImportBgButton_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon FontSize="12" Glyph="&#xE898;" />
                                            <TextBlock Text="导入图片" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <Border
                                Grid.Row="1"
                                x:Name="BgPreviewBorder"
                                Padding="0,1"
                                Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                                Visibility="Collapsed" />

                            <Grid Grid.Row="2" ColumnSpacing="16" x:Name="BgPreviewPanel" Visibility="Collapsed">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border
                                    Width="120"
                                    Height="68"
                                    CornerRadius="6"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1">
                                    <Image
                                        x:Name="BgPreviewImage"
                                        Stretch="UniformToFill" />
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                                    <TextBlock
                                        x:Name="BgFileNameText"
                                        FontSize="13"
                                        TextTrimming="CharacterEllipsis"
                                        MaxLines="1" />
                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <TextBlock FontSize="12" Opacity="0.68" VerticalAlignment="Center" Text="透明度" />
                                        <Slider
                                            x:Name="BgOpacitySlider"
                                            Width="160"
                                            ValueChanged="BgOpacitySlider_ValueChanged" />
                                        <TextBlock
                                            x:Name="BgOpacityText"
                                            FontSize="12"
                                            Opacity="0.68"
                                            VerticalAlignment="Center"
                                            Text="15%" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                            <Expander
                                x:Name="BgHistoryExpander"
                                Grid.Row="3"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                IsExpanded="False">
                                <Expander.Header>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon FontSize="14" Glyph="&#xE8B9;" Opacity="0.68" />
                                        <TextBlock Text="已导入的图片" />
                                        <TextBlock
                                            x:Name="BgHistoryCountText"
                                            Opacity="0.52"
                                            FontSize="12" />
                                    </StackPanel>
                                </Expander.Header>
                                <Expander.Content>
                                    <StackPanel Spacing="10" Padding="0,4,0,0">
                                        <ScrollViewer
                                            x:Name="BgListScrollViewer"
                                            HorizontalScrollBarVisibility="Auto"
                                            HorizontalScrollMode="Enabled"
                                            VerticalScrollBarVisibility="Disabled"
                                            VerticalScrollMode="Disabled">
                                            <StackPanel
                                                x:Name="BgListPanel"
                                                Orientation="Horizontal"
                                                Spacing="10" />
                                        </ScrollViewer>
                                        <TextBlock
                                            x:Name="BgListEmptyText"
                                            Opacity="0.52"
                                            FontSize="13"
                                            Text="还没有导入过图片"
                                            Visibility="Collapsed" />
                                    </StackPanel>
                                </Expander.Content>
                            </Expander>
                        </Grid>
                    </Border>

                    <Border x:Name="SettingsBrandLogoCard" Style="{StaticResource SettingsCardStyle}">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource IconBorderStyle}">
                                <FontIcon FontSize="18" Glyph="&#xEEA3;" />
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock FontWeight="SemiBold" Text="显示品牌 Logo" />
                                <TextBlock
                                    Opacity="0.68"
                                    FontSize="13"
                                    TextWrapping="Wrap"
                                    Text="在硬件信息页面的处理器和显卡行前显示品牌图标" />
                            </StackPanel>

                            <ToggleSwitch
                                x:Name="BrandLogoToggle"
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                Toggled="BrandLogoToggle_Toggled" />
                        </Grid>
                    </Border>

                    <Border x:Name="SettingsWatermarkCard" Style="{StaticResource SettingsCardStyle}">
                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Style="{StaticResource IconBorderStyle}">
                                    <FontIcon FontSize="18" Glyph="&#xE8B9;" />
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                    <TextBlock FontWeight="SemiBold" Text="截图水印" />
                                    <TextBlock
                                        Opacity="0.68"
                                        FontSize="13"
                                        TextWrapping="Wrap"
                                        Text="硬件信息截图时在右下角添加水印" />
                                </StackPanel>

                                <ToggleSwitch
                                    x:Name="WatermarkToggle"
                                    Grid.Column="2"
                                    VerticalAlignment="Center"
                                    Toggled="WatermarkToggle_Toggled" />
                            </Grid>

                            <Border
                                Grid.Row="1"
                                x:Name="WatermarkDivider"
                                Padding="0,1"
                                Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                            <Grid Grid.Row="2" ColumnSpacing="16" x:Name="WatermarkDetailPanel">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Style="{StaticResource IconBorderStyle}">
                                    <FontIcon FontSize="18" Glyph="&#xE8D2;" />
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                    <TextBlock FontWeight="SemiBold" Text="水印文字" />
                                    <TextBlock
                                        Opacity="0.68"
                                        FontSize="13"
                                        TextWrapping="Wrap"
                                        Text="自定义截图水印显示的文字" />
                                </StackPanel>

                                <TextBox
                                    x:Name="WatermarkTextBox"
                                    Grid.Column="2"
                                    MinWidth="160"
                                    MaxWidth="240"
                                    PlaceholderText="图吧工具箱"
                                    TextChanged="WatermarkTextBox_TextChanged" />
                            </Grid>

                            <Grid Grid.Row="3" ColumnSpacing="16" x:Name="WatermarkFontPanel">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Style="{StaticResource IconBorderStyle}">
                                    <FontIcon FontSize="18" Glyph="&#xE9F5;" />
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                    <TextBlock FontWeight="SemiBold" Text="水印字体" />
                                    <TextBlock
                                        Opacity="0.68"
                                        FontSize="13"
                                        TextWrapping="Wrap"
                                        Text="自定义截图水印使用的字体" />
                                </StackPanel>

                                <ComboBox
                                    x:Name="WatermarkFontComboBox"
                                    Grid.Column="2"
                                    MinWidth="160"
                                    SelectionChanged="WatermarkFontComboBox_SelectionChanged" />
                            </Grid>
                        </Grid>
                    </Border>

                </StackPanel>
            </RelativePanel>
        </ScrollViewer>
    </Grid>
</Page>
