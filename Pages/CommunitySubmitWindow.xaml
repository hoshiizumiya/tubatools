<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="TubaWinUi3.Pages.CommunitySubmitWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Padding="32,28,32,20" ColumnSpacing="16"
              Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border x:Name="IconBorder" Width="56" Height="56"
                    Background="#330066CC"
                    CornerRadius="14">
                <FontIcon x:Name="HeaderIcon" FontSize="28" Foreground="#0066CC" Glyph="&#xE898;" />
            </Border>

            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                <TextBlock x:Name="TitleText" FontSize="26" FontWeight="SemiBold" Text="正在提交" />
                <TextBlock x:Name="SubtitleText" Opacity="0.68" FontSize="13" TextWrapping="Wrap"
                           Text="正在将你的工具提交到社区仓库..." />
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" HorizontalScrollMode="Disabled"
                      VerticalScrollBarVisibility="Auto" Padding="32,20,32,8">
            <StackPanel x:Name="ContentPanel" Spacing="16" MaxWidth="860">

                <Border x:Name="ProgressCard" Padding="20"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="10">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontSize="14" Glyph="&#xE946;" Opacity="0.68" />
                            <TextBlock FontSize="14" FontWeight="SemiBold" Opacity="0.78" Text="提交进度" />
                        </StackPanel>
                        <ProgressBar x:Name="SubmitProgressBar" IsIndeterminate="True" />
                        <TextBlock x:Name="ProgressText" FontSize="13" Opacity="0.7" Text="正在 Fork 仓库..." />
                    </StackPanel>
                </Border>

                <Border x:Name="SuccessCard" Padding="20" Visibility="Collapsed"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="10">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontSize="14" Glyph="&#xE73E;" Foreground="#0F7B0F" />
                            <TextBlock FontSize="14" FontWeight="SemiBold" Text="提交成功" />
                        </StackPanel>
                        <TextBlock FontSize="13" Opacity="0.7" TextWrapping="Wrap"
                                   Text="你的工具已成功提交 Pull Request，审核通过后即可在社区中展示。" />
                        <HyperlinkButton x:Name="PrLink" Content="查看 Pull Request" Visibility="Collapsed" />
                    </StackPanel>
                </Border>

                <Border x:Name="ErrorCard" Padding="20" Visibility="Collapsed"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="10">
                    <StackPanel Spacing="12">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="14" Glyph="&#xE783;" Foreground="#FF4444" />
                                <TextBlock FontSize="14" FontWeight="SemiBold" Text="错误详情" />
                            </StackPanel>
                            <Button x:Name="CopyErrorButton" Grid.Column="1"
                                    Padding="10,4" Click="CopyErrorButton_Click"
                                    ToolTipService.ToolTip="复制错误信息"
                                    CornerRadius="6">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon FontSize="12" Glyph="&#xE8C8;" />
                                    <TextBlock x:Name="CopyErrorButtonText" FontSize="12" Text="复制" />
                                </StackPanel>
                            </Button>
                        </Grid>
                        <ScrollViewer MaxHeight="260" HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="ErrorText"
                                       FontFamily="Cascadia Code, Consolas"
                                       FontSize="12" Opacity="0.82"
                                       TextWrapping="Wrap" IsTextSelectionEnabled="True" />
                        </ScrollViewer>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Padding="32,16,32,20"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                <Button x:Name="CancelButton" Padding="20,10" Click="CancelButton_Click"
                        CornerRadius="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="14" Glyph="&#xE711;" />
                        <TextBlock Text="取消" />
                    </StackPanel>
                </Button>
                <Button x:Name="CloseButton" Padding="20,10" Click="CloseButton_Click"
                        Visibility="Collapsed" CornerRadius="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="14" Glyph="&#xE711;" />
                        <TextBlock Text="关闭" />
                    </StackPanel>
                </Button>
                <Button x:Name="RetryButton" Padding="20,10" Click="RetryButton_Click"
                        Visibility="Collapsed" CornerRadius="8"
                        Style="{ThemeResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="14" Glyph="&#xE72C;" />
                        <TextBlock Text="重试" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
