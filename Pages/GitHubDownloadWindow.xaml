<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="TubaWinUi3.Pages.GitHubDownloadWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Padding="32,28,32,20" ColumnSpacing="16"
              Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border x:Name="IconBorder" Width="56" Height="56"
                    Background="#330066CC"
                    CornerRadius="14">
                <FontIcon x:Name="HeaderIcon" FontSize="28" Foreground="#0066CC" Glyph="&#xE896;" />
            </Border>

            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                <TextBlock x:Name="TitleText" FontSize="26" FontWeight="SemiBold" Text="正在下载" />
                <TextBlock x:Name="SubtitleText" Opacity="0.68" FontSize="13" TextWrapping="Wrap"
                           Text="正在测速选择最佳下载源..." />
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" HorizontalScrollMode="Disabled"
                      VerticalScrollBarVisibility="Auto" Padding="32,20,32,8">
            <StackPanel Spacing="16" MaxWidth="860">

                <Border x:Name="InfoCard" Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="10">
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="InfoTitleText" FontSize="15" FontWeight="SemiBold" />
                        <TextBlock x:Name="InfoDescText" FontSize="13" Opacity="0.7" TextWrapping="Wrap" />
                        <TextBlock x:Name="InfoDetailText" FontSize="12" Opacity="0.6" />
                    </StackPanel>
                </Border>

                <Border x:Name="WarningCard" Padding="12,8,12,8" Visibility="Collapsed"
                        Background="#33FB923C"
                        BorderBrush="#50FB923C"
                        BorderThickness="1" CornerRadius="6">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE7BA;" FontSize="14" Foreground="#FFFB923C" />
                        <TextBlock x:Name="WarningText" FontSize="12" Opacity="0.8" TextWrapping="Wrap" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <Border x:Name="SpeedCard" Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="10">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon x:Name="SpeedIcon" Glyph="&#xEC27;" FontSize="14"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                            <TextBlock x:Name="SpeedStatusText" FontSize="13"
                                       Text="正在测速选择最佳下载源..." VerticalAlignment="Center" />
                        </StackPanel>
                        <ScrollViewer MaxHeight="180" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="SpeedListPanel" Spacing="2" />
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <Border x:Name="SourceCard" Padding="16" Visibility="Collapsed"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="10">
                    <StackPanel Spacing="8">
                        <TextBlock FontSize="13" Opacity="0.7" Text="选择下载源" />
                        <RadioButtons x:Name="SourceRadioButtons" />
                    </StackPanel>
                </Border>

                <Border x:Name="ProgressCard" Padding="16" Visibility="Collapsed"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="10">
                    <StackPanel Spacing="8">
                        <TextBlock x:Name="PercentText" FontSize="20" FontWeight="Bold"
                                   Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" Text="0%" />
                        <ProgressBar x:Name="DownloadProgressBar" IsIndeterminate="False" />
                        <StackPanel x:Name="StatsRow" Orientation="Horizontal" Spacing="20">
                            <StackPanel Spacing="2">
                                <TextBlock Text="速度" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                <TextBlock x:Name="SpeedValText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="--" />
                            </StackPanel>
                            <StackPanel Spacing="2">
                                <TextBlock Text="已下载" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                <TextBlock x:Name="SizeValText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="--" />
                            </StackPanel>
                            <StackPanel Spacing="2">
                                <TextBlock Text="剩余时间" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                <TextBlock x:Name="TimeValText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="--" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border x:Name="SuccessCard" Padding="16" Visibility="Collapsed"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="10">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontSize="14" Glyph="&#xE73E;" Foreground="#0F7B0F" />
                            <TextBlock FontSize="14" FontWeight="SemiBold" Text="下载完成" />
                        </StackPanel>
                        <TextBlock x:Name="SuccessDetailText" FontSize="13" Opacity="0.7" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border x:Name="ErrorCard" Padding="16" Visibility="Collapsed"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="10">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontSize="14" Glyph="&#xE783;" Foreground="#FF4444" />
                            <TextBlock FontSize="14" FontWeight="SemiBold" Text="下载失败" />
                        </StackPanel>
                        <TextBlock x:Name="ErrorText" FontSize="13" Opacity="0.8" TextWrapping="Wrap" IsTextSelectionEnabled="True" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Padding="32,16,32,20"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                <Button x:Name="CancelButton" Padding="20,10" Click="CancelButton_Click"
                        CornerRadius="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="14" Glyph="&#xE711;" />
                        <TextBlock Text="取消" />
                    </StackPanel>
                </Button>
                <Button x:Name="DownloadButton" Padding="20,10" Click="DownloadButton_Click"
                        IsEnabled="False" CornerRadius="8"
                        Style="{ThemeResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="14" Glyph="&#xE896;" />
                        <TextBlock Text="开始下载" />
                    </StackPanel>
                </Button>
                <Button x:Name="CloseButton" Padding="20,10" Click="CloseButton_Click"
                        Visibility="Collapsed" CornerRadius="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="14" Glyph="&#xE711;" />
                        <TextBlock Text="关闭" />
                    </StackPanel>
                </Button>
                <Button x:Name="RetryButton" Padding="20,10" Click="RetryButton_Click"
                        Visibility="Collapsed" CornerRadius="8"
                        Style="{ThemeResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="14" Glyph="&#xE72C;" />
                        <TextBlock Text="重试" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
