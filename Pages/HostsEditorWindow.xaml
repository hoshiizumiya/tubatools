<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="TubaWinUi3.Pages.HostsEditorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Grid Padding="24,20,24,12" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Border Width="40" Height="40" Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="8">
                <FontIcon FontSize="20" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" Glyph="&#xE779;" />
            </Border>
            <StackPanel Grid.Column="1" Spacing="2">
                <TextBlock FontSize="22" FontWeight="SemiBold" Text="Hosts 编辑" />
                <TextBlock x:Name="PathText" Opacity="0.68" FontSize="11" FontFamily="Consolas" IsTextSelectionEnabled="True" />
            </StackPanel>
            <Button x:Name="CloseButton" Grid.Column="2" Click="CloseButton_Click" Content="关闭" />
        </Grid>

        <!-- Main content -->
        <ScrollViewer Grid.Row="1" HorizontalScrollMode="Disabled" VerticalScrollBarVisibility="Auto" Padding="24,0,24,24">
            <StackPanel Spacing="14">
                <!-- Stat cards -->
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border x:Name="ActiveCard" Padding="12" CornerRadius="6" BorderThickness="1">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="ActiveIcon" Width="36" Height="36" CornerRadius="6">
                                <FontIcon FontSize="16" Glyph="&#xE73E;" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock FontSize="11" Opacity="0.68" Text="启用规则" />
                                <TextBlock x:Name="ActiveCountText" FontSize="22" FontWeight="Bold" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Border x:Name="DisabledCard" Grid.Column="1" Padding="12" CornerRadius="6" BorderThickness="1">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="DisabledIcon" Width="36" Height="36" CornerRadius="6">
                                <FontIcon FontSize="16" Glyph="&#xE894;" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock FontSize="11" Opacity="0.68" Text="禁用规则" />
                                <TextBlock x:Name="DisabledCountText" FontSize="22" FontWeight="Bold" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Border x:Name="AdminCard" Grid.Column="2" Padding="12" CornerRadius="6" BorderThickness="1">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="AdminIcon" Width="36" Height="36" CornerRadius="6">
                                <FontIcon FontSize="16" Glyph="&#xE77B;" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock FontSize="11" Opacity="0.68" Text="管理员" />
                                <TextBlock x:Name="AdminText" FontSize="22" FontWeight="Bold" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Action buttons -->
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Name="AddBtn" Click="AddBtn_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE710;" FontSize="12" />
                            <TextBlock Text="添加规则" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="SaveBtn" Click="SaveBtn_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE74E;" FontSize="12" />
                            <TextBlock Text="保存" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="BackupBtn" Click="BackupBtn_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE787;" FontSize="12" />
                            <TextBlock Text="备份" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="FlushBtn" Click="FlushBtn_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE72C;" FontSize="12" />
                            <TextBlock Text="刷新DNS" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="ReloadBtn" Click="ReloadBtn_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE777;" FontSize="12" />
                            <TextBlock Text="重载" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <InfoBar x:Name="ToastBar" IsClosable="True" IsOpen="False" />

                <!-- Column headers -->
                <Border x:Name="HeaderBorder" Padding="12,6,12,6" CornerRadius="6,6,0,0">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="80" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" FontSize="11" FontWeight="SemiBold" Opacity="0.68" Text="状态" />
                        <TextBlock Grid.Column="1" FontSize="11" FontWeight="SemiBold" Opacity="0.68" Text="IP 地址" />
                        <TextBlock Grid.Column="2" FontSize="11" FontWeight="SemiBold" Opacity="0.68" Text="主机名" />
                        <TextBlock Grid.Column="3" FontSize="11" FontWeight="SemiBold" Opacity="0.68" Text="备注" />
                        <TextBlock Grid.Column="4" FontSize="11" FontWeight="SemiBold" Opacity="0.68" Text="操作" />
                    </Grid>
                </Border>

                <!-- List -->
                <Border x:Name="ListBorder" BorderThickness="1" CornerRadius="0,0,6,6">
                    <StackPanel x:Name="ListContainer" />
                </Border>

                <!-- Loading -->
                <StackPanel x:Name="LoadingPanel" HorizontalAlignment="Center" Spacing="8" Padding="0,30,0,30" Visibility="Collapsed">
                    <ProgressRing x:Name="LoadingRing" Width="36" Height="36" IsActive="True" />
                    <TextBlock FontSize="13" Opacity="0.68" Text="正在加载 Hosts 文件..." />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
