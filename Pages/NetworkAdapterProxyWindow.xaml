<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="TubaWinUi3.Pages.NetworkAdapterProxyWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Grid Padding="20,16,20,8" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Border Width="36" Height="36" Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="8">
                <FontIcon FontSize="16" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" Glyph="&#xE968;" />
            </Border>
            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="网络调度器" />
                <TextBlock Opacity="0.6" FontSize="12" Text="根据实时负载自动均衡多网络流量" />
            </StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <ToggleSwitch x:Name="MonitorToggle" IsOn="True" OnContent="监控中" OffContent="已暂停" FontSize="12" Toggled="MonitorToggle_Toggled" />
                <Button x:Name="CloseButton" Click="CloseButton_Click" Padding="8,4">
                    <FontIcon Glyph="&#xE711;" FontSize="12" />
                </Button>
            </StackPanel>
        </Grid>

        <!-- Main content -->
        <ScrollViewer Grid.Row="1" HorizontalScrollMode="Disabled" VerticalScrollBarVisibility="Auto" Padding="20,0,20,20">
            <StackPanel Spacing="10">
                <InfoBar x:Name="ToastBar" IsClosable="True" IsOpen="False" />

                <!-- Adapter cards -->
                <TextBlock FontSize="13" FontWeight="SemiBold" Opacity="0.7" Text="网络适配器" Margin="0,2,0,0" />
                <Grid x:Name="AdapterCardsGrid" ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                </Grid>

                <!-- Auto schedule -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="14" Margin="0,4,0,0">
                    <StackPanel Spacing="10">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Glyph="&#xE9D9;" FontSize="18" VerticalAlignment="Center" Opacity="0.7" />
                            <TextBlock Grid.Column="1" FontSize="14" FontWeight="SemiBold" Text="自动调度" VerticalAlignment="Center" />
                            <ToggleSwitch x:Name="AutoScheduleToggle" IsOn="True" OnContent="运行中" OffContent="已关闭" FontSize="12" Toggled="AutoScheduleToggle_Toggled" Grid.Column="2" />
                        </Grid>
                        <TextBlock x:Name="ScheduleStatusText" FontSize="12" Opacity="0.6" Text="每 5 秒根据实时负载自动调整路由优先级" TextWrapping="Wrap" />
                        <StackPanel x:Name="ScheduleEntriesPanel" Spacing="6" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="ScheduleSummaryText" FontSize="11" Opacity="0.5" Text="" VerticalAlignment="Center" TextWrapping="Wrap" />
                            <Button x:Name="ResetBtn" Grid.Column="1" Click="ResetBtn_Click" CornerRadius="6" Padding="10,6" FontSize="12">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <FontIcon Glyph="&#xE72C;" FontSize="12" />
                                    <TextBlock Text="恢复默认" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Realtime speed -->
                <TextBlock FontSize="13" FontWeight="SemiBold" Opacity="0.7" Text="实时速度" Margin="0,4,0,0" />
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="14">
                    <Grid x:Name="SpeedGrid" ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                    </Grid>
                </Border>

                <!-- Active connections summary -->
                <Grid Margin="0,4,0,0" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock FontSize="13" FontWeight="SemiBold" Opacity="0.7" Text="活动连接" VerticalAlignment="Center" />
                    <HyperlinkButton x:Name="ViewConnectionsBtn" Grid.Column="1" Click="ViewConnectionsBtn_Click" Padding="4,2" FontSize="12">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="查看详情" />
                            <FontIcon Glyph="&#xE76C;" FontSize="10" />
                        </StackPanel>
                    </HyperlinkButton>
                </Grid>
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="14,10,14,10">
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="ConnSummaryText" FontSize="13" Opacity="0.7" Text="加载中..." />
                        <ProgressBar x:Name="ConnLoadingBar" IsIndeterminate="True" Visibility="Collapsed" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
