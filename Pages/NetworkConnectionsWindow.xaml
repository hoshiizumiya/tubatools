<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="TubaWinUi3.Pages.NetworkConnectionsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Padding="20,16,20,10" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Border Width="36" Height="36" Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="8">
                <FontIcon FontSize="16" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" Glyph="&#xE8BD;" />
            </Border>
            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="活动连接详情" />
                <TextBlock x:Name="SubtitleText" Opacity="0.6" FontSize="12" Text="TCP 连接实时监控" />
            </StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button x:Name="RefreshBtn" Click="RefreshBtn_Click" Padding="8,4">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE72C;" FontSize="12" />
                        <TextBlock Text="刷新" FontSize="12" />
                    </StackPanel>
                </Button>
                <ToggleSwitch x:Name="AutoRefreshToggle" IsOn="True" OnContent="自动" OffContent="手动" FontSize="12" />
                <Button x:Name="CloseButton" Click="CloseButton_Click" Padding="8,4">
                    <FontIcon Glyph="&#xE711;" FontSize="12" />
                </Button>
            </StackPanel>
        </Grid>

        <ProgressBar x:Name="LoadingBar" Grid.Row="1" IsIndeterminate="True" Visibility="Collapsed" />

        <ScrollViewer Grid.Row="2" HorizontalScrollMode="Disabled" VerticalScrollBarVisibility="Auto" Padding="20,0,20,16">
            <StackPanel Spacing="8">
                <Grid Padding="8,4" ColumnSpacing="8" x:Name="HeaderGrid">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="70" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition Width="100" />
                    </Grid.ColumnDefinitions>
                    <TextBlock FontSize="11" FontWeight="SemiBold" Opacity="0.5" Text="进程" />
                    <TextBlock FontSize="11" FontWeight="SemiBold" Opacity="0.5" Grid.Column="1" Text="类型" />
                    <TextBlock FontSize="11" FontWeight="SemiBold" Opacity="0.5" Grid.Column="2" Text="远程地址" />
                    <TextBlock FontSize="11" FontWeight="SemiBold" Opacity="0.5" Grid.Column="3" Text="端口" />
                    <TextBlock FontSize="11" FontWeight="SemiBold" Opacity="0.5" Grid.Column="4" Text="适配器" />
                </Grid>
                <StackPanel x:Name="ConnectionPanel" Spacing="2" />
                <StackPanel x:Name="EmptyPanel" Visibility="Collapsed" HorizontalAlignment="Center" Spacing="4" Padding="0,32,0,32">
                    <FontIcon Glyph="&#xE8BD;" FontSize="32" Opacity="0.3" />
                    <TextBlock Text="暂无已建立的 TCP 连接" Opacity="0.5" FontSize="13" HorizontalAlignment="Center" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
