<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="TubaWinUi3.Pages.PortViewerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Grid Padding="24,20,24,12" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Border Width="40" Height="40" Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="8">
                <FontIcon FontSize="20" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" Glyph="&#xE774;" />
            </Border>
            <StackPanel Grid.Column="1" Spacing="2">
                <TextBlock FontSize="22" FontWeight="SemiBold" Text="端口占用" />
                <TextBlock Opacity="0.68" FontSize="12" Text="通过 iphlpapi 扫描系统 TCP/UDP 连接，定位端口占用进程" />
            </StackPanel>
            <Button x:Name="CloseButton" Grid.Column="2" Click="CloseButton_Click" Content="关闭" />
        </Grid>

        <!-- Main content -->
        <ScrollViewer Grid.Row="1" HorizontalScrollMode="Disabled" VerticalScrollBarVisibility="Auto" Padding="24,0,24,24">
            <StackPanel Spacing="14">
                <InfoBar x:Name="ErrorBar" IsClosable="True" IsOpen="False" Severity="Error" />

                <!-- Action bar -->
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <AutoSuggestBox x:Name="SearchBox" PlaceholderText="搜索端口、进程名、PID、tcp6、地址..." MinWidth="240" QueryIcon="Find" TextChanged="SearchBox_TextChanged" QuerySubmitted="SearchBox_QuerySubmitted" />
                    <ComboBox x:Name="ProtoCombo" Grid.Column="1" MinWidth="100" SelectedIndex="0" SelectionChanged="ProtoCombo_SelectionChanged">
                        <x:String>全部</x:String>
                        <x:String>TCP</x:String>
                        <x:String>UDP</x:String>
                        <x:String>TCP6</x:String>
                        <x:String>UDP6</x:String>
                    </ComboBox>
                    <Button x:Name="RefreshBtn" Grid.Column="2" Click="RefreshBtn_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE72C;" FontSize="12" />
                            <TextBlock Text="刷新" />
                        </StackPanel>
                    </Button>
                    <TextBlock x:Name="CountText" Grid.Column="3" FontSize="12" Opacity="0.68" VerticalAlignment="Center" />
                </Grid>

                <!-- Column headers -->
                <Border x:Name="HeaderBorder" Padding="12,6,12,6" CornerRadius="6,6,0,0">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" FontSize="11" FontWeight="SemiBold" Opacity="0.68" Text="协议" />
                        <TextBlock Grid.Column="1" FontSize="11" FontWeight="SemiBold" Opacity="0.68" Text="端口" />
                        <TextBlock Grid.Column="2" FontSize="11" FontWeight="SemiBold" Opacity="0.68" Text="本地地址" />
                        <TextBlock Grid.Column="3" FontSize="11" FontWeight="SemiBold" Opacity="0.68" Text="状态" />
                        <TextBlock Grid.Column="4" FontSize="11" FontWeight="SemiBold" Opacity="0.68" Text="进程" />
                        <TextBlock Grid.Column="5" FontSize="11" FontWeight="SemiBold" Opacity="0.68" Text="PID" />
                        <TextBlock Grid.Column="6" FontSize="11" FontWeight="SemiBold" Opacity="0.68" Text="操作" />
                    </Grid>
                </Border>

                <!-- List -->
                <Border x:Name="ListBorder" BorderThickness="1" CornerRadius="0,0,6,6">
                    <StackPanel x:Name="ListContainer" />
                </Border>

                <!-- Loading -->
                <StackPanel x:Name="LoadingPanel" HorizontalAlignment="Center" Spacing="8" Padding="0,40,0,40" Visibility="Collapsed">
                    <ProgressRing x:Name="LoadingRing" Width="36" Height="36" IsActive="True" />
                    <TextBlock FontSize="13" Opacity="0.68" Text="正在扫描端口..." />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
