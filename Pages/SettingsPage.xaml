<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="TubaWinUi3.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TubaWinUi3.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    NavigationCacheMode="Enabled"
    mc:Ignorable="d">

    <Grid Background="Transparent">
        <ScrollViewer
            HorizontalScrollMode="Disabled"
            VerticalScrollBarVisibility="Auto">
            <RelativePanel HorizontalAlignment="Stretch">
                <StackPanel
                    x:Name="ContentPanel"
                    RelativePanel.AlignHorizontalCenterWithPanel="True"
                    RelativePanel.AlignLeftWithPanel="True"
                    RelativePanel.AlignRightWithPanel="True"
                    MaxWidth="1000"
                    Spacing="4"
                    Padding="40,28,40,48">
                    <StackPanel.Transitions>
                        <TransitionCollection>
                            <RepositionThemeTransition />
                        </TransitionCollection>
                    </StackPanel.Transitions>

                    <TextBlock
                        FontSize="28"
                        FontWeight="SemiBold"
                        Text="设置" />
                    <TextBlock
                        Opacity="0.72"
                        Margin="0,0,0,16"
                        Text="管理应用外观、更新及查看关于信息。" />

                    <Border Style="{StaticResource SettingsCardStyle}">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Image
                                x:Name="SettingsGifImage"
                                Width="56"
                                Height="56"
                                Stretch="UniformToFill" />

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Text="图吧工具箱" />
                                <TextBlock Opacity="0.68" Text="基于 WinUI 3 构建的 PC 硬件工具集合" />
                                <TextBlock
                                    x:Name="VersionText"
                                    Opacity="0.52"
                                    FontSize="12" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border
                        Style="{StaticResource NavCardBorderStyle}"
                        Tapped="NavGeneral_Tapped">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource NavCardIconBorderStyle}">
                                <FontIcon FontSize="20" Glyph="&#xE80F;" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock FontWeight="SemiBold" Text="常规" />
                                <TextBlock Opacity="0.68" FontSize="13" Text="主题、更新、启动页面、快速模式" />
                            </StackPanel>

                            <FontIcon Grid.Column="2" FontSize="14" Glyph="&#xE76C;" Opacity="0.5" VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <Border
                        Style="{StaticResource NavCardBorderStyle}"
                        Tapped="NavAppearance_Tapped">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource NavCardIconBorderStyle}">
                                <FontIcon FontSize="20" Glyph="&#xE7F3;" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock FontWeight="SemiBold" Text="外观" />
                                <TextBlock Opacity="0.68" FontSize="13" Text="窗口材质、背景图片、水印、品牌 Logo" />
                            </StackPanel>

                            <FontIcon Grid.Column="2" FontSize="14" Glyph="&#xE76C;" Opacity="0.5" VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <Border
                        Style="{StaticResource NavCardBorderStyle}"
                        Tapped="NavHardwareAi_Tapped">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource NavCardIconBorderStyle}">
                                <FontIcon FontSize="20" Glyph="&#xE772;" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock FontWeight="SemiBold" Text="硬件与 AI" />
                                <TextBlock Opacity="0.68" FontSize="13" Text="硬件显示选项、数据源、AI 服务配置" />
                            </StackPanel>

                            <FontIcon Grid.Column="2" FontSize="14" Glyph="&#xE76C;" Opacity="0.5" VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <Border
                        Style="{StaticResource NavCardBorderStyle}"
                        Tapped="NavToolsCommunity_Tapped">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource NavCardIconBorderStyle}">
                                <FontIcon FontSize="20" Glyph="&#xE8B7;" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock FontWeight="SemiBold" Text="工具与社区" />
                                <TextBlock Opacity="0.68" FontSize="13" Text="配置管理、自定义工具、导出、GitHub" />
                            </StackPanel>

                            <FontIcon Grid.Column="2" FontSize="14" Glyph="&#xE76C;" Opacity="0.5" VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <Border
                        Style="{StaticResource NavCardBorderStyle}"
                        Tapped="NavCredits_Tapped">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource NavCardIconBorderStyle}">
                                <FontIcon FontSize="20" Glyph="&#xE774;" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock FontWeight="SemiBold" Text="关于与鸣谢" />
                                <TextBlock Opacity="0.68" FontSize="13" Text="工具来源、作者、官网、开源引用" />
                            </StackPanel>

                            <FontIcon Grid.Column="2" FontSize="14" Glyph="&#xE76C;" Opacity="0.5" VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <Border
                        Style="{StaticResource NavCardBorderStyle}"
                        Tapped="NavWhatsNew_Tapped">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource NavCardIconBorderStyle}">
                                <FontIcon FontSize="20" Glyph="&#xE8BD;" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock FontWeight="SemiBold" Text="新增内容" />
                                <TextBlock Opacity="0.68" FontSize="13" Text="查看各版本更新日志和新功能" />
                            </StackPanel>

                            <FontIcon Grid.Column="2" FontSize="14" Glyph="&#xE76C;" Opacity="0.5" VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                </StackPanel>
            </RelativePanel>
        </ScrollViewer>
    </Grid>
</Page>
