<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="TubaWinUi3.Pages.ToolsCommunitySettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TubaWinUi3.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    NavigationCacheMode="Enabled"
    mc:Ignorable="d">

    <Grid Background="Transparent">
        <ScrollViewer
            HorizontalScrollMode="Disabled"
            VerticalScrollBarVisibility="Auto">
            <RelativePanel HorizontalAlignment="Stretch">
            <StackPanel
                RelativePanel.AlignHorizontalCenterWithPanel="True"
                RelativePanel.AlignLeftWithPanel="True"
                RelativePanel.AlignRightWithPanel="True"
                MaxWidth="1000"
                Spacing="2"
                Padding="40,28,40,48">

                <Button
                    x:Name="BackButton"
                    Padding="4"
                    MinWidth="0"
                    MinHeight="0"
                    VerticalAlignment="Center"
                    Click="BackButton_Click">
                    <FontIcon FontSize="14" Glyph="&#xE72B;" />
                </Button>

                <TextBlock
                    FontSize="28"
                    FontWeight="SemiBold"
                    Margin="0,8,0,0"
                    Text="工具与社区" />
                <TextBlock
                    Opacity="0.72"
                    Margin="0,0,0,16"
                    Text="配置管理、自定义工具和社区功能" />

                <TextBlock
                    Style="{StaticResource SectionHeaderStyle}"
                    Text="配置" />

                <Border x:Name="SettingsConfigManagerCard" Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource IconBorderStyle}">
                            <FontIcon FontSize="18" Glyph="&#xE912;" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontWeight="SemiBold" Text="配置管理" />
                            <TextBlock
                                Opacity="0.68"
                                FontSize="13"
                                TextWrapping="Wrap"
                                Text="管理配置文件的存储位置、导出和导入" />
                        </StackPanel>

                        <Button
                            x:Name="ConfigManagerButton"
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Padding="14,6"
                            Click="ConfigManagerButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontSize="12" Glyph="&#xE9D9;" />
                                <TextBlock Text="管理" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <TextBlock
                    Style="{StaticResource SectionHeaderStyle}"
                    Text="自定义工具" />

                <Border x:Name="SettingsCustomToolCard" Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource IconBorderStyle}">
                            <FontIcon FontSize="18" Glyph="&#xE8B7;" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontWeight="SemiBold" Text="自定义工具管理" />
                            <TextBlock
                                Opacity="0.68"
                                FontSize="13"
                                TextWrapping="Wrap"
                                Text="管理工具分类、导入自定义工具，支持拖拽排序" />
                        </StackPanel>

                        <Button
                            x:Name="CustomToolManagerButton"
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Padding="14,6"
                            Click="CustomToolManagerButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontSize="12" Glyph="&#xE9D9;" />
                                <TextBlock Text="管理" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <Border x:Name="SettingsExportAppCard" Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource IconBorderStyle}">
                            <FontIcon FontSize="18" Glyph="&#xE896;" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontWeight="SemiBold" Text="导出当前软件" />
                            <TextBlock
                                x:Name="ExportAppStatusText"
                                Opacity="0.68"
                                FontSize="13"
                                TextWrapping="Wrap"
                                Text="把当前程序目录、工具和元数据打包成可分发压缩包。" />
                        </StackPanel>

                        <Button
                            x:Name="ExportAppButton"
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Padding="14,6"
                            Click="ExportAppButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontSize="12" Glyph="&#xE896;" />
                                <TextBlock Text="导出" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <TextBlock
                    Style="{StaticResource SectionHeaderStyle}"
                    Text="社区" />

                <Border x:Name="SettingsCommunityCard" Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource IconBorderStyle}">
                            <FontIcon FontSize="18" Glyph="&#xE9D5;" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontWeight="SemiBold" Text="GitHub 账号" />
                            <TextBlock
                                x:Name="GitHubLoginStatusText"
                                Opacity="0.68"
                                FontSize="13"
                                TextWrapping="Wrap"
                                Text="未登录" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <PersonPicture
                                x:Name="GitHubAvatar"
                                Width="32"
                                Height="32"
                                Visibility="Collapsed" />
                            <Button
                                x:Name="GitHubLoginButton"
                                Padding="14,6"
                                Click="GitHubLoginButton_Click">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon FontSize="12" Glyph="&#xE77B;" />
                                    <TextBlock Text="登录" />
                                </StackPanel>
                            </Button>
                            <Button
                                x:Name="GitHubLogoutButton"
                                Padding="14,6"
                                Click="GitHubLogoutButton_Click"
                                Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon FontSize="12" Glyph="&#xE8AB;" />
                                    <TextBlock Text="登出" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border x:Name="SettingsCommunitySubmitCard" Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource IconBorderStyle}">
                            <FontIcon FontSize="18" Glyph="&#xE710;" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock FontWeight="SemiBold" Text="提交社区工具" />
                            <TextBlock
                                Opacity="0.68"
                                FontSize="13"
                                TextWrapping="Wrap"
                                Text="将工具提交到社区仓库，审核通过后所有人可见" />
                        </StackPanel>

                        <Button
                            x:Name="CommunitySubmitButton"
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Padding="14,6"
                            Click="CommunitySubmitButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontSize="12" Glyph="&#xE710;" />
                                <TextBlock Text="提交工具" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

            </StackPanel>
        </RelativePanel>
        </ScrollViewer>
    </Grid>
</Page>
