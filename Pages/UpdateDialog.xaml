<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="TubaWinUi3.Pages.UpdateDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="发现新版本"
    CloseButtonText="关闭">

    <ContentDialog.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <CornerRadius x:Key="DialogCornerRadius">12</CornerRadius>
        </ResourceDictionary>
    </ContentDialog.Resources>

    <Grid RowSpacing="16" MinWidth="500">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Version Header Card -->
        <Border
            Padding="24,20"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="10">
            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border
                    Width="56"
                    Height="56"
                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                    CornerRadius="16">
                    <FontIcon
                        FontSize="28"
                        Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                        Glyph="&#xE895;" />
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBlock
                            FontSize="24"
                            FontWeight="Bold"
                            Text="v" />
                        <TextBlock
                            x:Name="NewVersionText"
                            FontSize="24"
                            FontWeight="Bold" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Glyph="&#xE823;" />
                        <TextBlock
                            x:Name="PublishDateText"
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </StackPanel>

                <Border
                    Grid.Column="2"
                    Padding="10,5"
                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                    CornerRadius="6"
                    VerticalAlignment="Center">
                    <TextBlock
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                        Text="新版本" />
                </Border>
            </Grid>
        </Border>

        <!-- Action Buttons - 2x2 card-style grid -->
        <Grid
            x:Name="ActionButtonsPanel"
            Grid.Row="1"
            ColumnSpacing="10"
            RowSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- GitCode Download -->
            <Border
                x:Name="GitCodeCard"
                Padding="16,14"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Tapped="OnGitCodeDownloadClick">
                <Grid ColumnSpacing="14" RowSpacing="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Width="40"
                        Height="40"
                        Background="#1A7F37"
                        CornerRadius="10">
                        <FontIcon
                            FontSize="20"
                            Foreground="White"
                            Glyph="&#xE896;" />
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="GitCode 下载" />
                        <TextBlock
                            FontSize="11"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="国内加速，无需代理" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- GitHub Download -->
            <Border
                x:Name="GitHubCard"
                Grid.Column="1"
                Padding="16,14"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Tapped="OnGitHubDownloadClick">
                <Grid ColumnSpacing="14" RowSpacing="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Width="40"
                        Height="40"
                        Background="#6E40C9"
                        CornerRadius="10">
                        <FontIcon
                            FontSize="20"
                            Foreground="White"
                            Glyph="&#xE943;" />
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="GitHub 下载" />
                        <TextBlock
                            FontSize="11"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="官方源，全球加速" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Skip This Version -->
            <Border
                x:Name="SkipCard"
                Grid.Row="1"
                Padding="16,14"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Tapped="OnSkipVersionClick">
                <Grid ColumnSpacing="14" RowSpacing="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Width="40"
                        Height="40"
                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                        CornerRadius="10">
                        <FontIcon
                            FontSize="20"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Glyph="&#xE894;" />
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="跳过更新" />
                        <TextBlock
                            FontSize="11"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="本次跳过，下次仍提醒" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Ignore This Version -->
            <Border
                x:Name="IgnoreCard"
                Grid.Column="1"
                Grid.Row="1"
                Padding="16,14"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Tapped="OnIgnoreVersionClick">
                <Grid ColumnSpacing="14" RowSpacing="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Width="40"
                        Height="40"
                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                        CornerRadius="10">
                        <FontIcon
                            FontSize="20"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Glyph="&#xE711;" />
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="忽略版本" />
                        <TextBlock
                            FontSize="11"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="不再提醒此版本" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Changelog -->
        <Border
            Grid.Row="2"
            Padding="16"
            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
            CornerRadius="10"
            MaxHeight="200">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <RichTextBlock
                    x:Name="ChangelogText"
                    FontSize="13"
                    TextWrapping="Wrap"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    IsTextSelectionEnabled="True" />
            </ScrollViewer>
        </Border>

        <!-- Download Progress Section -->
        <StackPanel
            x:Name="DownloadSection"
            Grid.Row="3"
            Spacing="12"
            Visibility="Collapsed">

            <Border
                Padding="20,16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <ProgressRing
                            x:Name="DownloadRing"
                            Width="20"
                            Height="20"
                            IsActive="True" />
                        <TextBlock
                            x:Name="DownloadTitleText"
                            FontSize="14"
                            FontWeight="SemiBold"
                            VerticalAlignment="Center"
                            Text="正在下载更新" />
                    </StackPanel>

                    <ProgressBar
                        x:Name="DownloadProgressBar"
                        IsIndeterminate="False"
                        ShowError="False"
                        ShowPaused="False" />

                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon
                                    FontSize="11"
                                    Glyph="&#xE921;"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock
                                    x:Name="DownloadSpeedText"
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="--" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon
                                    FontSize="11"
                                    Glyph="&#xE8B7;"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock
                                    x:Name="DownloadSizeText"
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="--" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon
                                    FontSize="11"
                                    Glyph="&#xE917;"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock
                                    x:Name="DownloadTimeText"
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="--" />
                            </StackPanel>
                        </StackPanel>

                        <TextBlock
                            x:Name="DownloadPercentText"
                            Grid.Column="1"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                            Text="0%" />
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Error Section -->
        <InfoBar
            x:Name="ErrorInfoBar"
            Grid.Row="4"
            IsOpen="False"
            IsClosable="True"
            Severity="Error"
            Title="更新失败" />

    </Grid>
</ContentDialog>
